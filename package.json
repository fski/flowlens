{
  "private": true,
  "name": "flowlens",
  "version": "6.10.3",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/build.mjs --dev",
    "build:clean": "rm -rf dist && node scripts/build.mjs",
    "package": "node scripts/package.mjs",
    "package:audit": "node scripts/package-audit.mjs",
    "release:guard": "node scripts/release-guard.mjs",
    "audit:vendor": "node scripts/audit-vendor.mjs",
    "audit:vendor:all": "node scripts/audit-vendor-all.mjs",
    "release:check": "npm run build && npm run package && npm run package:audit && npm run release:guard",
    "ci": "npm test && npm run build && npm run package && npm run package:audit && npm run audit:vendor && npm run audit:vendor:all && npm run release:guard"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1"
  }
}
